model User {
    id         String     @id @default(uuid())
    name       String
    email      String     @unique
    password   String
    role       UserRole
    isBlocked  Boolean    @default(false)
    properties Property[] @relation("LandlordProperties")
    rentals    Rental[]
    payments   Payment[]
    reviews    Review[]
    createdAt  DateTime   @default(now())
    updatedAt  DateTime   @updatedAt
}
